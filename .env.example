# ==========================================
# Ego-UniRAG - Конфигурация окружения
# ==========================================
# Скопируйте этот файл в .env и заполните значениями
# cp .env.example .env

# ==========================================
# ProxiAPI Режим (ОСНОВНОЙ)
# ==========================================
# URL ProxiAPI прокси-сервера (российский провайдер)
# Доступ к GPT/Claude без VPN через российский прокси
PROXI_API_URL=https://api.proxyapi.ru/openai/v1

# API ключ ProxiAPI (если требуется авторизация)
# PROXI_API_KEY=your_proxi_api_key_here

# Модель по умолчанию через ProxiAPI (опционально)
# PROXI_API_MODEL=gpt-4o-mini

# ==========================================
# OpenAI API Режим (опционально)
# ==========================================
# API ключ OpenAI (используется только если не настроен ProxiAPI)
# OPENAI_API_KEY=your_openai_api_key_here

# ==========================================
# GigaChat Режим (опционально, резервный)
# ==========================================
# Ключ авторизации (Basic token)
# GIGACHAT_AUTH_KEY=your_gigachat_auth_key_here

# Уникальный идентификатор запроса (UUID)
# GIGACHAT_RQUID=your-gigachat-rquid-uuid-here
