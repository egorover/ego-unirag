# ==========================================
# Ego-UniRAG - Конфигурация окружения
# ==========================================
# Скопируйте этот файл в .env и заполните значениями
# cp .env.example .env

# ==========================================
# GigaChat Режим (Сбер)
# ==========================================
# Ключ авторизации (Basic token)
GIGACHAT_AUTH_KEY=your_gigachat_auth_key_here

# Уникальный идентификатор запроса (UUID)
GIGACHAT_RQUID=your-gigachat-rquid-uuid-here

# ==========================================
# OpenAI API Режим
# ==========================================
# API ключ OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# ==========================================
# ProxiAPI Режим
# ==========================================
# Прокси-сервер для доступа к зарубежным API
PROXI_API_URL=https://your-proxi-api-endpoint.com

# API ключ ProxiAPI (опционально, если требуется авторизация)
# PROXI_API_KEY=your_proxi_api_key_here

# Модель по умолчанию через ProxiAPI (опционально)
# PROXI_API_MODEL=gpt-4o-mini

# ==========================================
# Дополнительные настройки (опционально)
# ==========================================
# Путь к ChromaDB хранилищу
# CHROMADB_PERSIST_DIR=./chroma_db

# Размер кеша (количество записей)
# CACHE_MAX_SIZE=1000

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
